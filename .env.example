# Copy this file to .env and fill in your values

# PostgreSQL database connection string (required)
DATABASE_URL=postgresql://user:password@localhost:5432/optionsedge

# Session secret — any random string works locally
SESSION_SECRET=change-me-to-a-random-secret

# Public.com API key for live options chain data (optional — falls back to mock data)
PUBLIC_API_KEY=your_public_api_key_here

# --- Replit-only (leave blank when running locally) ---
# REPL_ID=
# ISSUER_URL=
# REPLIT_DOMAINS=
